# ──────────────────────────────────────────────
# База данных PostgreSQL
# ──────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=silvervy_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# ──────────────────────────────────────────────
# JWT (любая случайная строка, мин. 32 символа)
# ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here

# ──────────────────────────────────────────────
# Resend — отправка email-уведомлений о заказах
# Получить ключ: https://resend.com
# Для получения полноценного ключа необходим свой почтовый домен
# Если не нужна отправка писем — можно оставить пустым
# ──────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=email_with_your_domain

# ──────────────────────────────────────────────
# Окружение и порт
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
